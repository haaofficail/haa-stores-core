# ============================================================
# haastores.com — Production Environment Variables
# Copy to /home/haa/app/.env.production and fill all values
# DO NOT commit this file with real values
# ============================================================

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://haastores:CHANGE_PASSWORD@localhost:5432/haastores_production

# ── API ──────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=production
JWT_SECRET=GENERATE_WITH: openssl rand -hex 64
JWT_REFRESH_SECRET=GENERATE_WITH: openssl rand -hex 64
SESSION_SECRET=GENERATE_WITH: openssl rand -hex 32

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=https://haastores.com,https://merchant.haastores.com,https://admin.haastores.com

# ── Hosting (health endpoint) ────────────────────────────────────
HOSTING_REGION=me-jeddah-1
DATA_RESIDENCY=sa

# ── Email (Resend / SMTP) ────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@haastores.com

# ── File storage ─────────────────────────────────────────────────
# Option A: local disk (default, no config needed)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/home/haa/app/storage

# Option B: Oracle Object Storage (recommended for production)
# STORAGE_DRIVER=s3
# S3_ENDPOINT=https://NAMESPACE.compat.objectstorage.me-jeddah-1.oraclecloud.com
# S3_BUCKET=haastores-storage
# S3_ACCESS_KEY=XXXX
# S3_SECRET_KEY=XXXX
# S3_REGION=me-jeddah-1

# ── Payment gateways ─────────────────────────────────────────────
# Moyasar (MADA + Apple Pay + Credit Card)
MOYASAR_API_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXX
MOYASAR_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXX

# Geidea (optional)
# GEIDEA_MERCHANT_KEY=XXXX
# GEIDEA_PASSWORD=XXXX

# ── Redis (queue) ────────────────────────────────────────────────
# Leave empty to use noop queue mode (safe for start)
# REDIS_URL=redis://127.0.0.1:6379

# ── Queue mode ───────────────────────────────────────────────────
# Set to 'true' to allow noop queue (no Redis needed at first)
ALLOW_NOOP_QUEUE=true

# ── Notifications ────────────────────────────────────────────────
# Email via Resend (https://resend.com)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@haastores.com

# SMS via Unifonic (https://unifonic.com) — preferred in Saudi Arabia
# UNIFONIC_APP_SID=XXXXXXXXXXXXXXXXXXXXXXXX
# UNIFONIC_SENDER_ID=HaaStores
# UNIFONIC_WHATSAPP_SENDER=+966XXXXXXXXXX  # for WhatsApp channel

# SMS via Taqnyat (https://taqnyat.sa) — alternative to Unifonic
# TAQNYAT_BEARER_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXX
# TAQNYAT_SENDER_ID=HaaStores

# ── Shipping ─────────────────────────────────────────────────────
# Choose: manual | oto | aramex | smsa
SHIPPING_PROVIDER=manual
SHIPPING_MODE=sandbox

# OTO (default active)
# OTO_API_KEY=XXXX
# OTO_ACCESS_TOKEN=XXXX

# Aramex
# ARAMEX_USERNAME=XXXX
# ARAMEX_PASSWORD=XXXX
# ARAMEX_ACCOUNT_NUMBER=XXXX
# ARAMEX_ACCOUNT_PIN=XXXX
# ARAMEX_ACCOUNT_ENTITY=RUH
# ARAMEX_ACCOUNT_COUNTRY_CODE=SA
# ARAMEX_MODE=sandbox

# SMSA Express
# SMSA_PASS_KEY=XXXX
# SMSA_SENDER_ID=XXXX
# SMSA_MODE=sandbox

# ── ZATCA (e-invoicing — المرحلة الأولى والثانية) ────────────────
# Phase 1 — seller identity (required for QR + UBL XML, /merchant/:storeId/zatca/invoice)
# ZATCA_SELLER_NAME=شركة هاء للتجارة الإلكترونية
# ZATCA_VAT_NUMBER=300000000000003          # 15-digit VAT registration number
# ZATCA_STREET=شارع الملك فهد
# ZATCA_DISTRICT=العليا
# ZATCA_CITY=الرياض
# ZATCA_POSTAL_CODE=12211
# Phase 2 clearance — obtain PCSID from https://fatoora.zatca.gov.sa/
# Leave empty to use Phase 1 only (QR code on invoices)
# ZATCA_BASE_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/core
# ZATCA_PCSID=XXXX
# ZATCA_PCSID_SECRET=XXXX

# ── Social Login ─────────────────────────────────────────────────
# Google OAuth (https://console.cloud.google.com/)
# GOOGLE_CLIENT_ID=XXXX.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=XXXX
# API_BASE_URL=https://api.haastores.com
# MERCHANT_DASHBOARD_URL=https://merchant.haastores.com

# ── Monitoring ───────────────────────────────────────────────────
# SENTRY_DSN=https://XXXX@sentry.io/XXXX
