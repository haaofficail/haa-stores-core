{
  "$schema": "./tokens.schema.json",
  "description": "HAA Design Tokens — Source of Truth. Every value has a 'why' reference to 00-PHILOSOPHY/",
  "version": "1.0.0",
  "meta": {
    "grid": 8,
    "touchTarget": 44,
    "supportedPlatforms": ["web", "ios", "macos", "visionos", "tvos"]
  },
  "color": {
    "primary": {
      "description": "Brand primary color — Apple blue, vibrant and trustworthy",
      "why": "00-PHILOSOPHY/visual-language/03-color.md",
      "50":  { "srgb": "#f2f5ff",  "p3": "color(display-p3 0.949 0.961 1.000)", "contrast": "—" },
      "100": { "srgb": "#e0e8ff", "p3": "color(display-p3 0.878 0.910 1.000)", "contrast": "—" },
      "200": { "srgb": "#b3c6ff", "p3": "color(display-p3 0.702 0.776 1.000)", "contrast": "—" },
      "300": { "srgb": "#80a4ff", "p3": "color(display-p3 0.502 0.643 1.000)", "contrast": "—" },
      "400": { "srgb": "#4082ff", "p3": "color(display-p3 0.251 0.510 1.000)", "contrast": "—" },
      "500": { "srgb": "#007aff",  "p3": "color(display-p3 0.000 0.478 1.000)", "contrast": "4.8:1 (on #fff)" },
      "600": { "srgb": "#0066d6",  "p3": "color(display-p3 0.000 0.400 0.839)", "contrast": "5.5:1 (on #fff)" },
      "700": { "srgb": "#0055b3",  "p3": "color(display-p3 0.000 0.333 0.702)", "contrast": "7.0:1 (on #fff)" },
      "800": { "srgb": "#004499",  "p3": "color(display-p3 0.000 0.267 0.600)", "contrast": "—" },
      "900": { "srgb": "#003380",  "p3": "color(display-p3 0.000 0.200 0.502)", "contrast": "—" },
      "950": { "srgb": "#002266",  "p3": "color(display-p3 0.000 0.133 0.400)", "contrast": "—" }
    },
    "neutral": {
      "description": "Neutral grey palette — for text, surfaces, borders",
      "why": "00-PHILOSOPHY/visual-language/03-color.md",
      "50":  { "srgb": "#fafafa", "p3": "color(display-p3 0.980 0.980 0.980)", "contrast": "—" },
      "100": { "srgb": "#f5f5f5", "p3": "color(display-p3 0.961 0.961 0.961)", "contrast": "—" },
      "200": { "srgb": "#e5e5e5", "p3": "color(display-p3 0.898 0.898 0.898)", "contrast": "—" },
      "300": { "srgb": "#d4d4d4", "p3": "color(display-p3 0.831 0.831 0.831)", "contrast": "—" },
      "400": { "srgb": "#a3a3a3", "p3": "color(display-p3 0.639 0.639 0.639)", "contrast": "—" },
      "500": { "srgb": "#737373", "p3": "color(display-p3 0.451 0.451 0.451)", "contrast": "7.2:1 (on #fff)" },
      "600": { "srgb": "#525252", "p3": "color(display-p3 0.322 0.322 0.322)", "contrast": "—" },
      "700": { "srgb": "#404040", "p3": "color(display-p3 0.251 0.251 0.251)", "contrast": "—" },
      "800": { "srgb": "#262626", "p3": "color(display-p3 0.149 0.149 0.149)", "contrast": "—" },
      "900": { "srgb": "#171717", "p3": "color(display-p3 0.090 0.090 0.090)", "contrast": "15.3:1 (on #fff)" },
      "950": { "srgb": "#0a0a0a", "p3": "color(display-p3 0.039 0.039 0.039)", "contrast": "17.0:1 (on #fff)" }
    },
    "semantic": {
      "description": "Semantic colors — Apple exact colors",
      "why": "00-PHILOSOPHY/visual-language/03-color.md",
      "success": {
        "description": "Apple Green — success",
        "light": { "srgb": "#34c759", "p3": "color(display-p3 0.204 0.780 0.349)", "contrast": "3.2:1 (on #fff)" },
        "dark":  { "srgb": "#30d158", "p3": "color(display-p3 0.188 0.820 0.345)", "contrast": "6.5:1 (on #000)" },
        "textOnLight": "#ffffff",
        "textOnDark": "#1d1d1f",
        "subtle": { "light": "#e8f8ee", "dark": "rgb(48 209 88 / 0.15)" }
      },
      "warning": {
        "description": "Apple Orange — warning / caution",
        "light": { "srgb": "#ff9500", "p3": "color(display-p3 1.000 0.584 0.000)", "contrast": "2.8:1 (on #fff)" },
        "dark":  { "srgb": "#ff9f0a", "p3": "color(display-p3 1.000 0.624 0.039)", "contrast": "6.0:1 (on #000)" },
        "textOnLight": "#1d1d1f",
        "textOnDark": "#1d1d1f",
        "subtle": { "light": "#fff4e5", "dark": "rgb(255 159 10 / 0.15)" }
      },
      "danger": {
        "description": "Apple Red — destructive / error",
        "light": { "srgb": "#ff3b30", "p3": "color(display-p3 1.000 0.231 0.188)", "contrast": "4.6:1 (on #fff)" },
        "dark":  { "srgb": "#ff453a", "p3": "color(display-p3 1.000 0.271 0.227)", "contrast": "6.8:1 (on #000)" },
        "textOnLight": "#ffffff",
        "textOnDark": "#1d1d1f",
        "subtle": { "light": "#ffebeb", "dark": "rgb(255 69 58 / 0.15)" }
      },
      "info": {
        "description": "Apple Blue — informational",
        "light": { "srgb": "#007aff", "p3": "color(display-p3 0.000 0.478 1.000)", "contrast": "4.8:1 (on #fff)" },
        "dark":  { "srgb": "#0a84ff", "p3": "color(display-p3 0.039 0.518 1.000)", "contrast": "6.5:1 (on #000)" },
        "textOnLight": "#ffffff",
        "textOnDark": "#1d1d1f",
        "subtle": { "light": "#e8f2ff", "dark": "rgb(10 132 255 / 0.15)" }
      }
    },
    "platform": {
      "description": "Platform-specific color overrides",
      "ios": {
        "blue":   { "srgb": "#007aff" },
        "red":    { "srgb": "#ff3b30" },
        "green":  { "srgb": "#34c759" },
        "orange": { "srgb": "#ff9500" },
        "yellow": { "srgb": "#ffcc00" },
        "purple": { "srgb": "#af52de" },
        "pink":   { "srgb": "#ff2d55" },
        "gray":   { "srgb": "#8e8e93" }
      },
      "macos": {
        "blue":   { "srgb": "#007aff" },
        "red":    { "srgb": "#ff3b30" },
        "green":  { "srgb": "#28cd41" },
        "orange": { "srgb": "#ff9f0a" },
        "yellow": { "srgb": "#ffcc00" },
        "purple": { "srgb": "#bf5af2" },
        "pink":   { "srgb": "#ff375f" },
        "gray":   { "srgb": "#8e8e93" }
      }
    }
  },
  "typography": {
    "description": "Apple SF typography scale — Human-readable sizes",
    "why": "00-PHILOSOPHY/visual-language/02-typography.md",
    "fontFamily": {
      "sans":    "-apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
      "sansArabic": "system-ui, sans-serif",
      "mono":   "'JetBrains Mono', 'Fira Code', monospace",
      "japanese": "'Hiragino Kaku Gothic ProN', sans-serif",
      "korean":  "sans-serif",
      "chinese": "'Microsoft YaHei', sans-serif"
    },
    "typeScale": {
      "largeTitle": { "size": 34, "fontWeight": 400, "lineHeight": 41, "letterSpacing": 0.37 },
      "title1":     { "size": 28, "fontWeight": 400, "lineHeight": 34, "letterSpacing": 0.36 },
      "title2":     { "size": 22, "fontWeight": 400, "lineHeight": 28, "letterSpacing": 0.35 },
      "title3":     { "size": 20, "fontWeight": 600, "lineHeight": 25, "letterSpacing": 0.34 },
      "headline":   { "size": 17, "fontWeight": 600, "lineHeight": 22, "letterSpacing": -0.41 },
      "body":       { "size": 17, "fontWeight": 400, "lineHeight": 22, "letterSpacing": -0.41 },
      "callout":    { "size": 16, "fontWeight": 400, "lineHeight": 21, "letterSpacing": -0.32 },
      "subhead":    { "size": 15, "fontWeight": 400, "lineHeight": 20, "letterSpacing": -0.24 },
      "footnote":   { "size": 13, "fontWeight": 400, "lineHeight": 18, "letterSpacing": -0.07 },
      "caption1":   { "size": 12, "fontWeight": 400, "lineHeight": 16, "letterSpacing": 0 },
      "caption2":   { "size": 11, "fontWeight": 400, "lineHeight": 13, "letterSpacing": 0.06 }
    },
    "fontWeight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    }
  },
  "spacing": {
    "description": "8pt grid spacing — every value is a multiple of 8",
    "why": "00-PHILOSOPHY/why/8pt-grid.md",
    "0":  { "value": 0,  "rem": "0rem",  "usage": "none" },
    "1":  { "value": 8,  "rem": "0.5rem", "usage": "icon ↔ text gap" },
    "2":  { "value": 16, "rem": "1rem",   "usage": "related elements gap" },
    "3":  { "value": 24, "rem": "1.5rem", "usage": "card padding" },
    "4":  { "value": 32, "rem": "2rem",   "usage": "section padding" },
    "5":  { "value": 40, "rem": "2.5rem", "usage": "section between gap" },
    "6":  { "value": 48, "rem": "3rem",   "usage": "large section gap" },
    "8":  { "value": 64, "rem": "4rem",   "usage": "hero padding" },
    "10": { "value": 80, "rem": "5rem",   "usage": "major break" },
    "12": { "value": 96, "rem": "6rem",   "usage": "page section gap" }
  },
  "cornerRadius": {
    "description": "Apple exact corner radii — each value has a specific human factor",
    "why": "00-PHILOSOPHY/why/apple-radii.md",
    "micro":     { "value": 5.5,  "usage": "PiP, small tags", "platform": "ios" },
    "macBtn":    { "value": 6,    "usage": "macOS buttons",   "platform": "macos" },
    "sm":        { "value": 8,    "usage": "Badges, tags" },
    "md":        { "value": 12,   "usage": "Cards, sheets" },
    "iosBtn":    { "value": 14,   "usage": "iOS buttons",    "platform": "ios" },
    "lg":        { "value": 20,   "usage": "Dialogs, modals" },
    "iosIcon":   { "value": 20.5, "usage": "iOS app icons",  "platform": "ios" },
    "xl":        { "value": 24,   "usage": "Cards hero" },
    "pill":      { "value": 9999, "usage": "Pills, capsules" },
    "visionOs":  { "value": 28,   "usage": "visionOS glass", "platform": "visionos" }
  },
  "shadow": {
    "description": "Elevation shadows — correlates with layering levels",
    "why": "00-PHILOSOPHY/visual-language/04-layering.md",
    "sm": {
      "value": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
      "dark": "0 1px 2px 0 rgb(0 0 0 / 0.3)",
      "elevation": 1,
      "usage": "Cards, small surfaces"
    },
    "md": {
      "value": "0 4px 6px -1px rgb(0 0 0 / 0.1)",
      "dark": "0 4px 6px -1px rgb(0 0 0 / 0.4)",
      "elevation": 2,
      "usage": "Dropdowns, raised elements"
    },
    "lg": {
      "value": "0 10px 15px -3px rgb(0 0 0 / 0.1)",
      "dark": "0 10px 15px -3px rgb(0 0 0 / 0.5)",
      "elevation": 3,
      "usage": "Modals, sheets"
    },
    "xl": {
      "value": "0 20px 25px -5px rgb(0 0 0 / 0.1)",
      "dark": "0 20px 25px -5px rgb(0 0 0 / 0.5)",
      "elevation": 4,
      "usage": "Toasts, tooltips"
    }
  },
  "borderWidth": {
    "description": "Border width scale",
    "0": { "value": 0,  "usage": "no border" },
    "1": { "value": 1,  "usage": "default border" },
    "2": { "value": 2,  "usage": "focus ring, emphasis" },
    "4": { "value": 4,  "usage": "heavy emphasis" }
  },
  "opacity": {
    "description": "Opacity values for disabled, overlay, subtle states",
    "0":   { "value": 0,   "usage": "hidden" },
    "5":   { "value": 0.05, "usage": "subtle overlay, disabled text bg" },
    "10":  { "value": 0.1,  "usage": "very subtle" },
    "20":  { "value": 0.2,  "usage": "placeholder text" },
    "30":  { "value": 0.3,  "usage": "disabled icon" },
    "50":  { "value": 0.5,  "usage": "disabled element" },
    "70":  { "value": 0.7,  "usage": "loading state" },
    "100": { "value": 1,    "usage": "full opacity" }
  },
  "easing": {
    "description": "Timing functions — Apple-style spring physics",
    "why": "00-PHILOSOPHY/why/spring-physics.md",
    "springSnappy": {
      "value": "linear(0, 0.006, 0.025 2.8%, 0.101 6.1%, 0.539 18.9%, 0.721 25.3%, 0.849 31.5%, 0.937 38.1%, 0.968 41.8%, 0.991 46.4%, 1.006 51.6%, 1.015 58.4%, 1.017 63.3%, 1.001 78.9%, 1)",
      "appleEquivalent": "response: 0.4, dampingRatio: 0.8",
      "usage": "buttons, taps, small interactions"
    },
    "springSmooth": {
      "value": "linear(0, 0.003, 0.012 3.2%, 0.148 11.5%, 0.499 22.6%, 0.675 29.9%, 0.806 36.9%, 0.911 44.7%, 0.963 51.1%, 0.988 57.8%, 0.997 67.2%, 1)",
      "appleEquivalent": "response: 0.5, dampingRatio: 0.9",
      "usage": "modals, transitions, sheets"
    },
    "springBouncy": {
      "value": "linear(0, 0.007, 0.028 2.3%, 0.114 5.2%, 0.615 18.5%, 0.749 23%, 0.841 27.5%, 0.902 32%, 0.941 36.5%, 0.966 41%, 0.98 45.5%, 0.987 50%, 0.989 55%, 0.987 60%, 0.983 65%, 0.98 70%, 0.978 75%, 0.98 80%, 0.985 85%, 0.994 90%, 0.999 95%, 1)",
      "appleEquivalent": "response: 0.4, dampingRatio: 0.6",
      "usage": "celebrations, confirmations, playful interactions"
    },
    "linear": {
      "value": "linear",
      "usage": "progress bars, loading"
    },
    "easeOutExpo": {
      "value": "cubic-bezier(0.16, 1, 0.3, 1)",
      "usage": "exit animations"
    },
    "easeOutBack": {
      "value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "usage": "entrance with subtle overshoot"
    }
  },
  "zIndex": {
    "description": "Z-index scale — ordered stacking context",
    "why": "00-PHILOSOPHY/visual-language/04-layering.md",
    "base":    { "value": 0,   "usage": "default content" },
    "dropdown": { "value": 100, "usage": "menus, dropdowns" },
    "sticky":  { "value": 200, "usage": "sticky headers, sidebars" },
    "overlay": { "value": 300, "usage": "backdrop, overlay background" },
    "modal":   { "value": 400, "usage": "modals, dialogs" },
    "toast":   { "value": 500, "usage": "toasts, notifications" },
    "tooltip": { "value": 600, "usage": "tooltips, popovers" }
  },
  "gradient": {
    "description": "Gradient presets",
    "primary": {
      "value": "linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700))",
      "usage": "hero sections, primary CTAs"
    },
    "surface": {
      "value": "linear-gradient(180deg, var(--surface-1), var(--surface-2))",
      "usage": "cards, sections"
    },
    "glass": {
      "value": "linear-gradient(135deg, rgb(255 255 255 / 0.1), rgb(255 255 255 / 0))",
      "usage": "glassmorphism effects"
    },
    "mesh": {
      "value": "radial-gradient(circle at 30% 40%, var(--color-primary-200) 0%, transparent 50%)",
      "usage": "decorative backgrounds"
    },
    "glow": {
      "value": "radial-gradient(ellipse at center, var(--color-primary-400) 0%, transparent 70%)",
      "usage": "glow effects behind elements"
    }
  },
  "breakpoint": {
    "description": "Responsive breakpoints",
    "sm":  { "value": 640,  "unit": "px", "usage": "mobile" },
    "md":  { "value": 768,  "unit": "px", "usage": "tablet" },
    "lg":  { "value": 1024, "unit": "px", "usage": "desktop small" },
    "xl":  { "value": 1280, "unit": "px", "usage": "desktop" },
    "2xl": { "value": 1536, "unit": "px", "usage": "desktop wide" }
  },
  "responsive": {
    "description": "Responsive layout values",
    "maxWidth": {
      "content": { "value": 1200, "unit": "px", "usage": "content container" },
      "text":    { "value": 720,  "unit": "px", "usage": "readable text column (max 75ch)" }
    },
    "columnCount": {
      "sm":  4,
      "md":  8,
      "lg":  12,
      "xl":  12
    },
    "containerPadding": {
      "sm":  { "value": 16, "unit": "px" },
      "md":  { "value": 24, "unit": "px" },
      "lg":  { "value": 32, "unit": "px" },
      "xl":  { "value": 48, "unit": "px" }
    }
  },
  "duration": {
    "description": "Animation durations in milliseconds",
    "instant":   { "value": 50,  "usage": "micro-interactions, haptic feedback" },
    "fast":      { "value": 150, "usage": "button press, hover state" },
    "normal":    { "value": 300, "usage": "standard transitions" },
    "slow":      { "value": 500, "usage": "page transitions, modal appear" },
    "deliberate": { "value": 800, "usage": "special emphasis" }
  },
  "motion": {
    "description": "Motion choreography matrix per component",
    "button": {
      "press":   { "animation": "scale 0.96", "easing": "springSnappy", "duration": "fast" },
      "release": { "animation": "scale 1.0", "easing": "springBouncy", "duration": "normal" },
      "hover":   { "animation": "translateY -1px + shadow", "easing": "springSmooth", "duration": "fast" }
    },
    "modal": {
      "present": { "animation": "slideUp + scale 0.95→1 + fade", "easing": "springSmooth", "duration": "normal" },
      "dismiss": { "animation": "scale→0.95 + fade", "easing": "easeOutExpo", "duration": "fast" }
    },
    "sheet": {
      "drag":    { "animation": "follow finger", "easing": "springSmooth", "duration": "0" },
      "snap":    { "animation": "snap to point", "easing": "springSnappy", "duration": "normal" }
    },
    "list": {
      "appear":  { "animation": "fadeIn + translateY(10)", "easing": "springSmooth", "duration": "normal", "stagger": 50 },
      "reorder": { "animation": "layout transition", "easing": "springSnappy", "duration": "normal" }
    },
    "page": {
      "push":    { "animation": "slideFromRight", "easing": "springSmooth", "duration": "normal" },
      "pop":     { "animation": "slideToRight", "easing": "springSmooth", "duration": "normal" },
      "fade":    { "animation": "crossFade", "easing": "easeOutExpo", "duration": "normal" }
    },
    "toast": {
      "enter":   { "animation": "slideDown + fade", "easing": "springSnappy", "duration": "fast" },
      "exit":    { "animation": "fadeOut + slideUp", "easing": "easeOutExpo", "duration": "normal" }
    },
    "switch": {
      "toggle":  { "animation": "thumb slide 44pt", "easing": "springSnappy", "duration": "fast" }
    },
    "progress": {
      "fill":    { "animation": "width/scale change", "easing": "easeOutExpo", "duration": "normal" }
    }
  },
  "iconSizes": {
    "description": "Icon size scale for storefront UI",
    "why": "Spec Skill 2: Icon Governance",
    "xs":  { "value": 16, "unit": "px", "usage": "metadata, small inline icons" },
    "sm":  { "value": 18, "unit": "px", "usage": "small button icons" },
    "md":  { "value": 20, "unit": "px", "usage": "default button icons" },
    "default": { "value": 24, "unit": "px", "usage": "default UI icons" },
    "lg":  { "value": 32, "unit": "px", "usage": "feature/trust icons" },
    "xl":  { "value": 48, "unit": "px", "usage": "empty-state icons" },
    "2xl": { "value": 64, "unit": "px", "usage": "illustrations, large empty states" }
  },
  "buttonHeight": {
    "description": "Button height scale for storefront CTAs",
    "why": "Spec Skill 6: Button & CTA System",
    "sm":  { "value": 32, "unit": "px", "usage": "small button" },
    "md":  { "value": 40, "unit": "px", "usage": "medium button" },
    "lg":  { "value": 48, "unit": "px", "usage": "large button, primary CTA" }
  },
  "badgeTokens": {
    "description": "Badge size and style tokens",
    "why": "Spec Skill 7: Badge & Label System",
    "height":     { "value": 20, "unit": "px", "usage": "badge height" },
    "paddingX":   { "value": 8,  "unit": "px", "usage": "badge horizontal padding" },
    "fontSize":   { "value": 11, "unit": "px", "usage": "badge font size" },
    "radius":     { "value": 9999, "unit": "px", "usage": "badge border radius (pill)" },
    "iconSize":   { "value": 12, "unit": "px", "usage": "badge icon size" }
  },
  "cardTokens": {
    "description": "Product card and surface card layout tokens",
    "why": "Spec Skill 3: Product Card Equalizer",
    "padding":        { "value": 16, "unit": "px", "usage": "card inner padding" },
    "radius":         { "value": 16, "unit": "px", "usage": "card border radius" },
    "imageRadius":    { "value": 12, "unit": "px", "usage": "product image radius" },
    "gap":            { "value": 12, "unit": "px", "usage": "card internal gap" },
    "titleLineClamp": { "value": 2,  "unit": "",   "usage": "max title lines" },
    "actionMinHeight": { "value": 40, "unit": "px", "usage": "add-to-cart button area" },
    "priceHeight":    { "value": 24, "unit": "px", "usage": "reserved price row height" },
    "badgeReserved":  { "value": 20, "unit": "px", "usage": "reserved badge area height" }
  },
  "sectionTokens": {
    "description": "Page section and container layout tokens",
    "why": "Spec Skill 4: Storefront Page Rhythm System",
    "sectionGap":     { "value": 48, "unit": "px", "usage": "between major sections" },
    "sectionHeaderGap": { "value": 24, "unit": "px", "usage": "section title to content" },
    "containerMaxWidth": { "value": 1280, "unit": "px", "usage": "max container width" },
    "containerPaddingSm":  { "value": 16, "unit": "px", "usage": "mobile container padding" },
    "containerPaddingMd":  { "value": 24, "unit": "px", "usage": "tablet container padding" },
    "containerPaddingLg":  { "value": 32, "unit": "px", "usage": "desktop container padding" }
  },
  "touchTarget": {
    "description": "Minimum touch target sizes (Apple HIG: 44pt + WCAG 2.2)",
    "why": "00-PHILOSOPHY/why/44pt.md",
    "default":  { "value": 44, "unit": "pt", "usage": "all interactive elements" },
    "minimum":  { "value": 24, "unit": "pt", "usage": "WCAG 2.2 absolute minimum (SC 2.5.8)" },
    "compact":  { "value": 32, "unit": "pt", "usage": "exceptional: compact spaces only" },
    "icon":     { "value": 40, "unit": "pt", "usage": "icon-only button target" },
    "drag":     { "value": 48, "unit": "pt", "usage": "draggable elements" },
    "between":  { "value": 8,  "unit": "px", "usage": "gap between touch targets" }
  },
  "safeArea": {
    "description": "Safe area insets — for devices with notches, Dynamic Island, home indicator",
    "why": "00-PHILOSOPHY/why/safe-areas.md",
    "top":     { "css": "env(safe-area-inset-top, 0px)" },
    "bottom":  { "css": "env(safe-area-inset-bottom, 0px)" },
    "left":    { "css": "env(safe-area-inset-left, 0px)" },
    "right":   { "css": "env(safe-area-inset-right, 0px)" }
  },
  "material": {
    "description": "Material/vibrancy levels for glass effects",
    "why": "00-PHILOSOPHY/visual-language/07-materials.md",
    "ultraThin":  { "lightBackground": "rgba(255,255,255,0.2)", "darkBackground": "rgba(0,0,0,0.2)", "blur": 80, "usage": "distant background" },
    "thin":       { "lightBackground": "rgba(255,255,255,0.3)", "darkBackground": "rgba(0,0,0,0.3)", "blur": 60, "usage": "navigation bars" },
    "regular":    { "lightBackground": "rgba(255,255,255,0.5)", "darkBackground": "rgba(0,0,0,0.5)", "blur": 40, "usage": "sheets, sidebars" },
    "thick":      { "lightBackground": "rgba(255,255,255,0.6)", "darkBackground": "rgba(0,0,0,0.6)", "blur": 20, "usage": "modals" },
    "ultraThick": { "lightBackground": "rgba(255,255,255,0.7)", "darkBackground": "rgba(0,0,0,0.7)", "blur": 10, "usage": "popovers" },
    "visionOs":   { "lightBackground": "linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0.05))", "blur": 60, "border": "0.5px solid rgba(255,255,255,0.2)", "usage": "visionOS glass" }
  },
  "accessibility": {
    "description": "Accessibility settings and thresholds",
    "why": "00-PHILOSOPHY/human-factors/05-accessibility.md",
    "contrast": {
      "aa":  4.5,
      "aaa": 7.0,
      "ui":  3.0
    },
    "dynamicType": {
      "xs":  0.85,
      "s":   0.95,
      "m":   1.0,
      "l":   1.15,
      "xl":  1.3,
      "xxl": 1.5,
      "xxxl": 1.8
    },
    "colorBlindness": {
      "types": ["protanopia", "deuteranopia", "tritanopia"],
      "validation": "required"
    }
  },
  "platformAdaptation": {
    "description": "Platform-specific overrides",
    "web": {
      "detection": "@media (hover: hover) and (pointer: fine)",
      "behavior": "hover + focus ring + keyboard nav",
      "cornerRadius": "var(--radius-sm), var(--radius-md)"
    },
    "ios": {
      "detection": "@media (pointer: coarse), (hover: none) and (pointer: coarse)",
      "behavior": "no hover, touch feedback, haptic",
      "cornerRadius": "var(--radius-ios-btn), var(--radius-ios-icon)"
    },
    "macos": {
      "detection": "@media (hover: hover) and (pointer: fine)",
      "behavior": "hover + focus ring + keyboard shortcuts",
      "cornerRadius": "var(--radius-mac-btn)"
    },
    "visionos": {
      "detection": "@media (dynamic-range: high)",
      "behavior": "glass materials, depth, gaze interaction",
      "cornerRadius": "var(--radius-vision-os)"
    },
    "tvos": {
      "detection": "@media (hover: hover) and (pointer: coarse)",
      "behavior": "focus engine, parallax, large text",
      "cornerRadius": "var(--radius-md)"
    }
  }
}
