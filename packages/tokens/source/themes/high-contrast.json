{
  "description": "High Contrast theme — WCAG AAA with Apple system colors",
  "extends": "base",
  "theme": {
    "surface": {
      "1": { "value": "#ffffff", "usage": "main background" },
      "2": { "value": "#e8e8ed", "usage": "cards, sections" },
      "3": { "value": "#d2d2d7", "usage": "hover states" },
      "inverse": { "value": "#000000" }
    },
    "text": {
      "primary":   { "value": "#000000", "contrast": "21.0:1" },
      "secondary": { "value": "#1d1d1f", "contrast": "16.0:1" },
      "tertiary":  { "value": "#3a3a3c", "contrast": "10.0:1" },
      "disabled":  { "value": "#86868b", "contrast": "5.0:1" },
      "inverse":   { "value": "#ffffff", "contrast": "21.0:1" },
      "link":      { "value": "#0040dd", "contrast": "8.5:1" },
      "linkHover": { "value": "#0030aa" }
    },
    "border": {
      "default":  { "value": "#86868b", "usage": "default border" },
      "hover":    { "value": "#636366", "usage": "border on hover" },
      "focus":    { "value": "#0040dd", "usage": "focus ring" },
      "disabled": { "value": "#aeaeb2", "usage": "disabled border" }
    },
    "divider": { "value": "#86868b" },
    "shadow": {
      "color":        { "value": "rgb(0 0 0 / 0.2)" },
      "colorStrong":  { "value": "rgb(0 0 0 / 0.35)" }
    },
    "backdrop": {
      "opacity": 0.7,
      "blur": 4,
      "color": { "value": "#000000" }
    },
    "selection": {
      "background": { "value": "#0066d6" },
      "text":       { "value": "#ffffff" }
    },
    "placeholder": {
      "text": { "value": "#636366" }
    }
  }
}
