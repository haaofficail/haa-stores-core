# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgres://haa:haa_secret_2024@localhost:5432/haastores
# Separate database for vitest tests (isolated from dev data).
# Auto-derived from DATABASE_URL by default (haastores_test); override if needed.
# TEST_DATABASE_URL=postgres://haa:haa_secret_2024@localhost:5432/haastores_test
# DATABASE_MAX_CONNECTIONS=20    # Pool size (default 20, tune for production)
# DATABASE_IDLE_TIMEOUT=30000    # Close idle connections after ms (default 30000)
# DATABASE_CONNECT_TIMEOUT=10000 # Connection timeout in ms (default 10000)

# ─── MinIO ─────────────────────────────────────────────
MINIO_ROOT_USER=haaadmin
MINIO_ROOT_PASSWORD=haa_secret_2024
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=haaadmin
MINIO_SECRET_KEY=haa_secret_2024
MINIO_BUCKET=haa-stores

# ─── Auth / JWT ────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h
ADMIN_JWT_EXPIRES_IN=24h

# ─── API ───────────────────────────────────────────────
API_PORT=3000
API_BASE_URL=http://localhost:3000

# ─── Merchant Dashboard ───────────────────────────────
MERCHANT_DASHBOARD_URL=http://localhost:5173

# ─── Storefront ────────────────────────────────────────
STOREFRONT_URL=http://localhost:5174

# ─── Encryption ────────────────────────────────────────
ENCRYPTION_KEY=dev-encryption-key-32-chars-minimum!!

# ─── Payment ──────────────────────────────────────────
PAYMENT_PROVIDER=geidea         # approved provider: geidea
PAYMENT_MODE=sandbox            # sandbox only — live is BLOCKED
# GEIDEA_MERCHANT_PUBLIC_KEY=
# GEIDEA_API_PASSWORD=
# GEIDEA_API_BASE_URL=https://api.merchant.geidea.net
# GEIDEA_CALLBACK_URL=
# GEIDEA_RETURN_URL=
# PAYMENT_SANDBOX_SECRET_KEY=    # Required for sandbox mode (Moyasar test secret key)
# PAYMENT_SANDBOX_PUBLIC_KEY=    # Required for sandbox mode (Moyasar test publishable key)
# PAYMENT_WEBHOOK_SECRET=        # HMAC secret for webhook signature verification

# ─── BNPL — Tabby ─────────────────────────────────────
# TABBY_SECRET_KEY=              # Tabby API secret key (sandbox/live)
# TABBY_PUBLIC_KEY=              # Tabby API public key
# TABBY_COUNTRY=SA               # Country code: SA (api.tabby.sa) or AE/KW (api.tabby.ai)

# ─── BNPL — Tamara ────────────────────────────────────
# TAMARA_API_TOKEN=              # Tamara API token (sandbox/live)
# TAMARA_WEBHOOK_TOKEN=          # Tamara notification/webhook token for signature verification

# ─── Payment Credentials Encryption ────────────────────
# AES-256-GCM key for encrypting merchant payment credentials at rest.
# Must be exactly 64 hex characters (32 bytes).
# Required when saving payment provider credentials (Tabby/Tamara merchant keys).
# PAYMENT_CREDENTIALS_ENCRYPTION_KEY=00001111222233334444555566667777aaaaaaaaaaaabbbbbbbbbbcccccccccc

# ─── Webhook ───────────────────────────────────────────
WEBHOOK_RETRY_MAX_ATTEMPTS=3
WEBHOOK_RETRY_INTERVAL_MS=5000

# ─── CORS ─────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Rate Limiting ────────────────────────────────────
# RATE_LIMIT_STORE=memory    # Backend: 'memory' (default) or 'redis' (not yet implemented)
# REDIS_URL=                 # Required for RATE_LIMIT_STORE=redis

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=debug

# ─── Storage ──────────────────────────────────────────
# local (development) or s3 (staging/production)
STORAGE_DRIVER=local

# S3/R2 variables (required when STORAGE_DRIVER=s3)
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=haa-stores-staging
# S3_ACCESS_KEY_ID=<your-access-key>
# S3_SECRET_ACCESS_KEY=<your-secret-key>
# S3_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# ── Shipping ──────────────────────────────────────────
# SHIPPING_PROVIDER=manual|haa_mock|oto
# SHIPPING_MODE=manual|mock|sandbox
# OTO_PLATFORM_MODE=sandbox
# OTO_API_BASE_URL=https://staging-api.tryoto.com
# OTO_MARKETPLACE_TOKEN=         # special OTO Marketplace token for multi-vendor registration
# OTO_API_KEY=                   # merchant-token fallback only
# OTO_ACCESS_TOKEN=              # merchant-token fallback only
# OTO_SANDBOX_API_KEY=
# OTO_WEBHOOK_SECRET=
# OTO_WEBHOOK_PUBLIC_KEY=
# OTO_WEBHOOK_AUTHORIZATION_KEY=
# SHIPPING_MODE=live is BLOCKED

# ── Email Contact ─────────────────────────────────────
# Contact-only fallback is info@haasoft.com until SMTP is configured.
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=

# ── AI Agent (Local LLM) ──────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Marketplaces ────────────────────────────────────────
# سلة (Salla) — OAuth 2.0
# SALLA_CLIENT_ID=
# SALLA_CLIENT_SECRET=
# SALLA_REDIRECT_URI=http://localhost:3000/api/merchant/{storeId}/marketplaces/salla/oauth/callback

# زد (Zid) — OAuth 2.0 + X-Manager-Token
# ZID_CLIENT_ID=
# ZID_CLIENT_SECRET=
# ZID_REDIRECT_URI=http://localhost:3000/api/merchant/{storeId}/marketplaces/zid/oauth/callback

# نون (Noon) — JWT (RS256 self-signed, no env vars needed, credentials entered via UI)

# أمازون (Amazon SP-API) — LWA OAuth + AWS SigV4
# AMAZON_CLIENT_ID=
# AMAZON_CLIENT_SECRET=
# AMAZON_APP_CLIENT_ID=   # Same as client ID for OAuth consent URL
# AMAZON_AWS_ACCESS_KEY=
# AMAZON_AWS_SECRET_KEY=
