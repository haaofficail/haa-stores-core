# Haa Stores — Staging reverse proxy (Caddy v2)
# ---------------------------------------------------------------------------
# Automatic HTTPS (Let's Encrypt) for the three staging hostnames. Requires
# DNS A records pointing each name at the staging server and ports 80/443 open:
#
#   staging.haastores.com           A   72.61.108.208
#   admin.staging.haastores.com     A   72.61.108.208
#   merchant.staging.haastores.com  A   72.61.108.208
#
# The SPA images are built with VITE_API_URL=/api, so each frontend calls the
# API under the /api/* prefix on its own origin. Caddy strips /api and forwards
# to the api service; /health is proxied for the deploy health check; everything
# else is served by the SPA. This avoids the /s/:slug path collision between the
# storefront's API endpoints and its client-side page routes.

{
	email haa.officail@gmail.com
}

(spa_site) {
	# Deploy health check + API. handle_path strips the /api prefix before
	# proxying, so /api/s/x -> api:/s/x.
	handle /health* {
		reverse_proxy api:3001
	}
	handle_path /api/* {
		reverse_proxy api:3001
	}
	encode gzip zstd
}

staging.haastores.com {
	import spa_site
	handle {
		reverse_proxy storefront:80
	}
}

admin.staging.haastores.com {
	import spa_site
	handle {
		reverse_proxy admin-dashboard:80
	}
}

merchant.staging.haastores.com {
	import spa_site
	handle {
		reverse_proxy merchant-dashboard:80
	}
}
