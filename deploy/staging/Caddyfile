# Haa Stores — Staging reverse proxy (Caddy v2)
# ---------------------------------------------------------------------------
# The staging server is currently also the official Haa Stores target. Public
# Haa-owned hostnames must be declared explicitly before the catch-all :443
# custom-domain block; otherwise Caddy treats them as merchant custom domains
# and the TLS ask gate can reject certificate issuance.

{
	email haa.officail@gmail.com

	on_demand_tls {
		ask http://api:3001/internal/tls-check
	}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}
}

(admin_security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}
}

(spa_site) {
	handle /health* {
		reverse_proxy api:3001
	}
	handle_path /api/* {
		reverse_proxy api:3001
	}
	encode gzip zstd
}

www.haastores.com {
	redir https://haastores.com{uri} permanent
}

haastores.com {
	import security_headers
	import spa_site
	handle {
		reverse_proxy storefront:80
	}
}

admin.haastores.com {
	import admin_security_headers
	import spa_site
	handle {
		reverse_proxy admin-dashboard:80
	}
}

merchant.haastores.com {
	import security_headers
	import spa_site
	handle {
		reverse_proxy merchant-dashboard:80
	}
}

dashboard.haastores.com {
	redir https://merchant.haastores.com{uri} permanent
}

api.haastores.com {
	import security_headers
	encode gzip zstd
	reverse_proxy api:3001
}

staging.haastores.com {
	import security_headers
	import spa_site
	handle {
		reverse_proxy storefront:80
	}
}

admin.staging.haastores.com {
	import admin_security_headers
	import spa_site
	handle {
		reverse_proxy admin-dashboard:80
	}
}

merchant.staging.haastores.com {
	import security_headers
	import spa_site
	handle {
		reverse_proxy merchant-dashboard:80
	}
}

:443 {
	tls {
		on_demand
	}
	import security_headers
	import spa_site
	handle {
		reverse_proxy storefront:80
	}
}
