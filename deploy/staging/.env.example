# Haa Stores — Staging environment
# Copy to `.env` on the staging server (/srv/haa-stores/.env) and fill in real
# secrets. NEVER commit the filled-in .env. Generate strong random secrets:
#   openssl rand -hex 24   (JWT secrets)
#   openssl rand -hex 32   (ENCRYPTION_KEY — needs >= 32 chars)
#   openssl rand -hex 16   (DB password)

# ── REQUIRED — the API refuses to boot without these ───────────────────────
# DATABASE_URL host must be the compose service name `postgres`, and its
# password MUST equal POSTGRES_PASSWORD below.
DATABASE_URL=postgres://haa:CHANGE_ME_DB_PASSWORD@postgres:5432/haastores
JWT_SECRET=CHANGE_ME_min_16_chars
ADMIN_JWT_SECRET=CHANGE_ME_min_16_chars
ENCRYPTION_KEY=CHANGE_ME_at_least_32_characters_long

# ── Postgres container ─────────────────────────────────────────────────────
POSTGRES_DB=haastores
POSTGRES_USER=haa
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── API runtime ────────────────────────────────────────────────────────────
NODE_ENV=staging
# Must match the api image's exposed port (3001) and the compose healthcheck.
API_PORT=3001
REDIS_URL=redis://redis:6379
QUEUE_REDIS_URL=redis://redis:6379
# Run without a separate worker container on staging (in-process noop queue).
ALLOW_NOOP_QUEUE=true
API_BASE_URL=https://staging.haastores.com
STOREFRONT_URL=https://staging.haastores.com
MERCHANT_DASHBOARD_URL=https://merchant.staging.haastores.com
CORS_ORIGINS=https://staging.haastores.com,https://admin.staging.haastores.com,https://merchant.staging.haastores.com
LOG_LEVEL=info

# ── Providers — keep staging on safe fakes unless you have sandbox creds ────
PAYMENT_PROVIDER=fake
PAYMENT_MODE=fake
SHIPPING_PROVIDER=manual
SHIPPING_MODE=manual
STORAGE_DRIVER=local

# ── Image coordinates ──────────────────────────────────────────────────────
# Normally exported by .github/workflows/deploy.yml; these defaults let you run
# `docker compose` by hand on the server. A real deploy pins IMAGE_TAG=sha-xxxx.
REGISTRY=ghcr.io
IMAGE_PREFIX=haaofficail/haa-stores
IMAGE_TAG=latest
