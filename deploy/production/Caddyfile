# Haa Stores — Production reverse proxy (Caddy v2)
# ---------------------------------------------------------------------------
# Automatic HTTPS (Let's Encrypt) for the three production hostnames. Requires
# DNS A records pointing each name at the production server and ports 80/443 open:
#
#   haastores.com           A   <production-server-ip>
#   admin.haastores.com     A   <production-server-ip>
#   merchant.haastores.com  A   <production-server-ip>
#
# The www subdomain redirects to the apex. The SPA images are built with
# VITE_API_URL=/api, so each frontend calls the API under the /api/* prefix
# on its own origin. Caddy strips /api and forwards to the api service.

{
	email haa.officail@gmail.com

	# On-demand TLS for merchant custom domains (QA Custom Domain). Before
	# issuing a Let's Encrypt cert for an unknown host, Caddy asks the API;
	# it returns 200 only for an ACTIVE custom domain, blocking
	# cert-exhaustion abuse from arbitrary hostnames. Rate limited.
	on_demand_tls {
		ask http://api:3001/internal/tls-check
		interval 2m
		burst 5
	}
}

(security_headers) {
	# Edge-level security headers. Defined on Caddy because the SPA nginx
	# `add_header` directives are silently overridden by per-location
	# blocks (nginx inheritance gotcha) — moving them up here guarantees
	# every response carries them regardless of which nginx location
	# served the request.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}
}

(admin_security_headers) {
	# Admin gets the stricter set — DENY framing + no-referrer.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}
}

(spa_site) {
	handle /health* {
		reverse_proxy api:3001
	}
	handle_path /api/* {
		reverse_proxy api:3001
	}
	encode gzip zstd
}

www.haastores.com {
	redir https://haastores.com{uri} permanent
}

haastores.com {
	import security_headers
	import spa_site
	handle {
		reverse_proxy storefront:80
	}
}

admin.haastores.com {
	import admin_security_headers
	import spa_site
	handle {
		reverse_proxy admin-dashboard:80
	}
}

merchant.haastores.com {
	import security_headers
	import spa_site
	handle {
		reverse_proxy merchant-dashboard:80
	}
}

# Merchant custom domains (QA Custom Domain). Any host NOT matched above is a
# candidate custom domain: serve the storefront SPA with on-demand TLS. The
# SPA bootstraps the right store via GET /api/resolve-host (Host header). The
# on_demand ask gate above ensures certs are only issued for active domains.
:443 {
	tls {
		on_demand
	}
	import security_headers
	import spa_site
	handle {
		reverse_proxy storefront:80
	}
}
