# Haa Stores — Production reverse proxy (Caddy v2)
# ---------------------------------------------------------------------------
# Automatic HTTPS (Let's Encrypt) for production hostnames. Requires DNS A
# records pointing each name at the production server and ports 80/443 open:
#
#   haastores.com           A   <production-server-ip>
#   admin.haastores.com     A   <production-server-ip>
#   merchant.haastores.com  A   <production-server-ip>
#   api.haastores.com       A   <production-server-ip>
#
# The www subdomain redirects to the apex. The SPA images are built with
# VITE_API_URL=/api, so each frontend calls the API under the /api/* prefix
# on its own origin. Caddy strips /api and forwards to the api service.

{
	email haa.officail@gmail.com

	on_demand_tls {
		ask http://api:3001/internal/tls-check
	}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}
}

(admin_security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}
}

(spa_site) {
	handle /health* {
		reverse_proxy api:3001
	}
	handle_path /api/* {
		reverse_proxy api:3001
	}
	encode gzip zstd

	# Cache policy (mirrors staging — see deploy/staging/Caddyfile for rationale).
	@vite_hashed path_regexp ^/assets/[^/]+-[A-Za-z0-9_-]{8,}\.(js|css|woff2?|ttf|otf|map)$
	header @vite_hashed Cache-Control "public, max-age=31536000, immutable"

	@unhashed_static path_regexp \.(svg|png|jpg|jpeg|webp|gif|ico|webmanifest|json)$
	header @unhashed_static Cache-Control "public, max-age=300, must-revalidate"

	@html_doc path / *.html
	header @html_doc Cache-Control "no-cache, no-store, must-revalidate"
}

www.haastores.com {
	redir https://haastores.com{uri} permanent
}

haastores.com {
	import security_headers
	import spa_site
	handle {
		reverse_proxy storefront:80
	}
}

admin.haastores.com {
	import admin_security_headers
	import spa_site
	handle {
		reverse_proxy admin-dashboard:80
	}
}

merchant.haastores.com {
	import security_headers
	import spa_site
	handle {
		reverse_proxy merchant-dashboard:80
	}
}

dashboard.haastores.com {
	redir https://merchant.haastores.com{uri} permanent
}

api.haastores.com {
	import security_headers
	encode gzip zstd
	reverse_proxy api:3001
}

:443 {
	tls {
		on_demand
	}
	import security_headers
	import spa_site
	handle {
		reverse_proxy storefront:80
	}
}
