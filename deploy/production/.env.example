# Haa Stores — Production environment template
# ---------------------------------------------------------------------------
# Copy this to deploy/production/.env on the production server and fill in all
# values. NEVER commit the real .env file — it contains live credentials.
#
# All keys marked [REQUIRED] must be set before first deploy.
# All keys marked [GEIDEA] must be set when PAYMENT_PROVIDER=geidea.
# All keys marked [OTO] must be set when SHIPPING_PROVIDER=oto.

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# [REQUIRED] Primary write connection
DATABASE_URL=postgresql://haa:CHANGE_ME@postgres:5432/haastores_prod

# [REQUIRED] Read replica (or same as DATABASE_URL if no replica)
DATABASE_READ_URL=postgresql://haa:CHANGE_ME@postgres:5432/haastores_prod

# Docker compose postgres credentials (loaded by docker-compose.yml)
POSTGRES_DB=haastores_prod
POSTGRES_USER=haa
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
# [REQUIRED]
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379
QUEUE_REDIS_URL=redis://:CHANGE_ME@redis:6379

# ── Secrets ──────────────────────────────────────────────────────────────────
# [REQUIRED] Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME

# [REQUIRED] Generate with: openssl rand -hex 32 (exactly 32 bytes / 64 hex chars)
ENCRYPTION_KEY=CHANGE_ME

# ── API ───────────────────────────────────────────────────────────────────────
# [REQUIRED]
API_PORT=3001
API_BASE_URL=https://haastores.com/api
MERCHANT_DASHBOARD_URL=https://merchant.haastores.com
STOREFRONT_URL=https://haastores.com
CORS_ORIGINS=https://haastores.com,https://admin.haastores.com,https://merchant.haastores.com

# ── Storage (S3 / Cloudflare R2) ─────────────────────────────────────────────
# [REQUIRED] local is rejected in production by env.ts
STORAGE_DRIVER=s3
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=haa-stores-prod
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_PUBLIC_BASE_URL=https://cdn.haastores.com

# [REQUIRED]
CDN_PUBLIC_BASE_URL=https://cdn.haastores.com

# ── Observability ─────────────────────────────────────────────────────────────
# [REQUIRED]
SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0
OTEL_EXPORTER_OTLP_ENDPOINT=https://CHANGE_ME

# ── Payment: Geidea ──────────────────────────────────────────────────────────
# Set PAYMENT_PROVIDER=geidea and fill all [GEIDEA] keys before going live.
# PAYMENT_PROVIDER=fake is BLOCKED in production by env.ts.
# PAYMENT_MODE=live is BLOCKED in the payment factory until whitelisted.
PAYMENT_PROVIDER=geidea
PAYMENT_MODE=sandbox

# [GEIDEA] Live credentials from Geidea merchant portal
GEIDEA_MERCHANT_PUBLIC_KEY=CHANGE_ME
GEIDEA_API_PASSWORD=CHANGE_ME

# [GEIDEA] Optional — defaults to Geidea production API if unset
# GEIDEA_API_BASE_URL=https://api.merchant.geidea.net

# [GEIDEA] Webhook / redirect URLs (must match Geidea portal settings)
GEIDEA_CALLBACK_URL=https://haastores.com/api/payments/geidea/callback
GEIDEA_RETURN_URL=https://haastores.com/checkout/result

# ── Shipping: OTO ─────────────────────────────────────────────────────────────
# Set SHIPPING_PROVIDER=oto and fill all [OTO] keys before going live.
# SHIPPING_MODE=live is BLOCKED in the shipping factory until whitelisted.
SHIPPING_PROVIDER=oto
SHIPPING_MODE=sandbox

# [OTO] Live credentials from OTO dashboard
OTO_API_KEY=CHANGE_ME
OTO_MARKETPLACE_TOKEN=CHANGE_ME

# [OTO] Webhook verification
OTO_WEBHOOK_SECRET=CHANGE_ME
OTO_WEBHOOK_PUBLIC_KEY=CHANGE_ME
OTO_WEBHOOK_AUTHORIZATION_KEY=CHANGE_ME

# [OTO] Platform mode: 'live' or 'sandbox'
OTO_PLATFORM_MODE=live

# ── Worker / Queue ────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10
ALLOW_NOOP_QUEUE=false
ENABLE_SCHEDULER=true

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.CHANGE_ME.com
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME

# ── Hosting metadata ─────────────────────────────────────────────────────────
HOSTING_REGION=sa-riyadh
DATA_RESIDENCY=in-ksa

# ── Docker image ─────────────────────────────────────────────────────────────
# Set by the deploy workflow — do not hardcode here
# IMAGE_TAG=sha-CHANGE_ME
REGISTRY=ghcr.io
IMAGE_PREFIX=haaofficail/haa-stores
